<Window x:Class="VisionInspect.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:local="clr-namespace:VisionInspect.ViewModels"
        xmlns:conv="clr-namespace:VisionInspect.Converters"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="通用视觉检测平台"
        Height="800" Width="1400"
        MinHeight="480" MinWidth="960"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Border Grid.Row="0" Background="#F0F0F0" Padding="8,6" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="新建流程" Command="{Binding NewRecipeCommand}" Margin="0,0,4,0" Padding="10,4"/>
                <Button Content="加载流程" Command="{Binding LoadRecipeCommand}" Margin="0,0,4,0" Padding="10,4"/>
                <Button Content="保存" Command="{Binding SaveRecipeCommand}" Margin="0,0,4,0" Padding="10,4"/>
                <Separator Width="1" Margin="8,2" Background="#C0C0C0"/>
                <Button Content="添加步骤" Command="{Binding AddStepCommand}" Margin="8,0,4,0" Padding="10,4"/>
                <Button Content="删除步骤" Command="{Binding DeleteStepCommand}" Margin="0,0,4,0" Padding="10,4"/>
                <Button Content="上移" Command="{Binding MoveUpCommand}" Margin="0,0,4,0" Padding="10,4"/>
                <Button Content="下移" Command="{Binding MoveDownCommand}" Margin="0,0,4,0" Padding="10,4"/>
                <Separator Width="1" Margin="8,2" Background="#C0C0C0"/>
                <Button Content="▶ 执行全部" Command="{Binding RunCommand}" Margin="8,0,4,0"
                        Padding="10,4" Background="#4CAF50" Foreground="White"/>
                <Button Content="▶ 单步执行" Command="{Binding StepRunCommand}" Margin="0,0,4,0"
                        Padding="10,4" Background="#FF9800" Foreground="White"/>
                <Button Content="■ 停止" Command="{Binding StopCommand}" Margin="0,0,4,0"
                        Padding="10,4" Background="#F44336" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：步骤列表 -->
            <Border Grid.Column="0" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#E8E8E8" Padding="10,8">
                        <TextBlock Text="检测步骤" FontSize="14" FontWeight="Bold"/>
                    </Border>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Steps}"
                             SelectedItem="{Binding SelectedStepNode, Mode=TwoWay}"
                             x:Name="StepListBox" Margin="0,4,0,0"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="2,1"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Border" Padding="8,6" Background="Transparent"
                                                    CornerRadius="2">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#D6E4F0"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#E8E8E8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" FontSize="13">
                                        <Run Text="["/><Run Text="{Binding StepType}" FontWeight="Bold"/>
                                        <Run Text="] "/><Run Text="{Binding StepName}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="Gray" FontSize="11"
                                               Text="{Binding StatusText}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent"/>

            <!-- 中间：图像显示 + 底部面板（结果/日志） -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="220"/>
                </Grid.RowDefinitions>

                <!-- 图像显示区 -->
                <Border Grid.Row="0" Background="#1E1E1E" Margin="4">
                    <Grid>
                        <Image Source="{Binding CurrentImage}" Stretch="Uniform"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="图像显示区域"
                                   Foreground="#555" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding HasImage, Converter={StaticResource InverseBoolToVis}}"/>
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="Transparent"/>

                <!-- 底部面板：结果 + 日志 标签切换 -->
                <Border Grid.Row="2" Background="#FAFAFA" Margin="4,0,4,4">
                    <TabControl>
                        <TabItem Header="执行结果">
                            <DataGrid ItemsSource="{Binding Results}" AutoGenerateColumns="False"
                                      IsReadOnly="True" HeadersVisibility="Column"
                                      BorderThickness="0" Background="White">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="步骤" Binding="{Binding StepName}" Width="120"/>
                                    <DataGridTextColumn Header="结果" Binding="{Binding Result}" Width="70">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Result}" Value="NG">
                                                        <Setter Property="Foreground" Value="Red"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Result}" Value="OK">
                                                        <Setter Property="Foreground" Value="Green"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="耗时(ms)" Binding="{Binding ElapsedMs}" Width="70"/>
                                    <DataGridTextColumn Header="输出" Binding="{Binding OutputSummary}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="运行日志">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Button Grid.Row="0" Content="清空日志" Command="{Binding ClearLogCommand}"
                                        HorizontalAlignment="Right" Margin="0,0,0,4" Padding="8,2"
                                        FontSize="11"/>
                                <ListBox Grid.Row="1" ItemsSource="{Binding LogEntries}"
                                         Background="White" BorderThickness="0"
                                         VirtualizingPanel.ScrollUnit="Pixel"
                                         x:Name="LogListBox">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="50"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding TimeText}"
                                                           Foreground="#888" FontSize="11"
                                                           FontFamily="Consolas" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding LevelText}"
                                                           FontSize="11" FontWeight="Bold"
                                                           FontFamily="Consolas" VerticalAlignment="Center"
                                                           Margin="4,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding LevelText}" Value="INFO">
                                                                    <Setter Property="Foreground" Value="#2196F3"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding LevelText}" Value="WARNING">
                                                                    <Setter Property="Foreground" Value="#FF9800"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding LevelText}" Value="ERROR">
                                                                    <Setter Property="Foreground" Value="#F44336"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding LevelText}" Value="FATAL">
                                                                    <Setter Property="Foreground" Value="#D32F2F"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding LevelText}" Value="DEBUG">
                                                                    <Setter Property="Foreground" Value="#888"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding LevelText}" Value="TRACE">
                                                                    <Setter Property="Foreground" Value="#AAA"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Grid.Column="2" Text="{Binding Message}"
                                                           FontSize="11" FontFamily="Consolas"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent"/>

            <!-- 右侧：属性面板 -->
            <Border Grid.Column="4" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#E8E8E8" Padding="10,8">
                        <TextBlock Text="属性面板" FontSize="14" FontWeight="Bold"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="8,4">
                        <StackPanel>
                            <GroupBox Header="步骤信息" Margin="0,0,0,8" Padding="4">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock Text="名称:" Width="50" Foreground="Gray"
                                                   VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding SelectedStepName, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="180" Margin="4,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="类型:" Width="50" Foreground="Gray"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox ItemsSource="{Binding AvailableProcessors}"
                                                  SelectedItem="{Binding SelectedProcessorType}"
                                                  Width="180" Margin="4,0,0,0"/>
                                    </StackPanel>
                                    <CheckBox Content="失败时停止" IsChecked="{Binding SelectedStepStopOnFailure}"
                                              Margin="0,4,0,0"/>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="算子参数" Margin="0,0,0,8" Padding="4">
                                <ItemsControl ItemsSource="{Binding SelectedStepParams}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="2,2" Margin="0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="120"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="11"
                                                                   Foreground="#555"/>
                                                        <TextBlock Text="{Binding ValueType}" FontSize="9"
                                                                   Foreground="#AAA"/>
                                                    </StackPanel>
                                                    <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                             FontSize="11" Padding="2"
                                                             VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Background="#E0E0E0" Padding="10,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}" VerticalAlignment="Center"
                           Foreground="#333"/>
                <TextBlock Grid.Column="1" Text="{Binding CameraStatus}" VerticalAlignment="Center"
                           Foreground="#555" Margin="20,0"/>
                <TextBlock Grid.Column="2" Text="{Binding PlcStatus}" VerticalAlignment="Center"
                           Foreground="#555" Margin="20,0"/>
                <TextBlock Grid.Column="3" Text="{Binding ProgressText}" VerticalAlignment="Center"
                           Foreground="#555" Margin="20,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>