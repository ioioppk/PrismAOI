{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://visioninspect.local/schemas/recipe-schema.json",
  "title": "InspectionRecipe - 检测配方定义",
  "description": "通用视觉检测平台的标准检测配方 JSON Schema。定义图像采集、检测、测量等步骤的完整流程。",
  "type": "object",
  "required": ["id", "name", "version", "steps"],
  "properties": {
    "id": {
      "type": "string",
      "description": "配方唯一标识符，如 demo_001",
      "examples": ["demo_001", "chip_inspect_v2"]
    },
    "name": {
      "type": "string",
      "description": "配方可读名称",
      "examples": ["演示流程-芯片缺陷检测", "PCB焊点检测"]
    },
    "version": {
      "type": "string",
      "description": "配方版本号",
      "default": "1.0",
      "examples": ["1.0", "2.1"]
    },
    "description": {
      "type": "string",
      "description": "配方用途描述"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "创建时间 (ISO 8601)"
    },
    "modifiedAt": {
      "type": "string",
      "format": "date-time",
      "description": "最后修改时间 (ISO 8601)"
    },
    "steps": {
      "type": "array",
      "description": "检测步骤列表，按顺序执行",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/InspectionStep"
      }
    }
  },
  "definitions": {
    "InspectionStep": {
      "type": "object",
      "required": ["id", "name", "type", "subSteps"],
      "properties": {
        "id": {
          "type": "string",
          "description": "步骤唯一标识，如 step_acquire",
          "examples": ["step_acquire", "step_grayscale", "step_blob"]
        },
        "name": {
          "type": "string",
          "description": "步骤显示名称",
          "examples": ["图像采集", "灰度化", "Blob缺陷检测"]
        },
        "type": {
          "type": "string",
          "enum": ["ImageAcquisition", "Alignment", "Inspection", "Measurement", "Communication", "SystemOperation"],
          "description": "步骤类型：ImageAcquisition=图像采集, Alignment=定位对位, Inspection=检测, Measurement=测量, Communication=通讯, SystemOperation=系统操作"
        },
        "stopOnFailure": {
          "type": "boolean",
          "description": "步骤失败时是否终止整个流程。默认 true",
          "default": true
        },
        "subSteps": {
          "type": "array",
          "description": "该步骤包含的算子节点列表",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/ProcessorNode"
          }
        },
        "config": {
          "type": "object",
          "description": "步骤级额外配置（预留扩展）",
          "additionalProperties": true
        }
      }
    },
    "ProcessorNode": {
      "type": "object",
      "required": ["id", "processorType"],
      "properties": {
        "id": {
          "type": "string",
          "description": "算子节点唯一标识，如 node_acquire_1",
          "examples": ["node_acquire_1", "node_gray_1", "node_blob_1"]
        },
        "processorType": {
          "type": "string",
          "description": "算子处理器类型标识，对应 IImageProcessor.Id。内置算子：Acquisition(图像采集), GrayScale(灰度化), BlobAnalysis(Blob分析)",
          "examples": ["Acquisition", "GrayScale", "BlobAnalysis"]
        },
        "inputReference": {
          "type": "string",
          "description": "输入数据引用，格式为 stepId.Output，指向前序步骤的输出",
          "examples": ["step_acquire.Output", "step_grayscale.Output"]
        },
        "parameters": {
          "type": "object",
          "description": "算子参数键值对，具体参数取决于 processorType",
          "additionalProperties": true,
          "examples": [
            { "ImagePath": "C:\\Images\\chip_sample.bmp", "CameraId": "" },
            { "MinArea": 100, "MaxArea": 999999, "Threshold": 128, "Invert": false }
          ]
        }
      }
    }
  }
}